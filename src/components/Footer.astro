---
import type { Lang } from '../i18n/translations';
import { translations, langPrefix, links, mainSite, subHref, siteHref } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = translations[lang];
const p = langPrefix(lang);
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a class="brand" href={p || '/'}>
        <img src="/logos/brand.svg" alt="" width="26" height="26" />
        <span>Luminus<strong>OS</strong></span>
      </a>
      <p>{t.footer.tagline}</p>
    </div>

    <nav aria-label={t.footer.project}>
      <h3>{t.footer.project}</h3>
      <a href={`${mainSite}${p}/#why`}>{t.nav.overview}</a>
      <a href={`${mainSite}${p}/#how`}>{t.nav.how}</a>
      <a href={`${mainSite}${p}/#editions`}>{t.nav.editions}</a>
      <a href={subHref(p, 'aurora', '/aurora', links.auroraSite)}>{t.nav.aurora}</a>
      <a href={`${mainSite}${p}/aetheris`}>{t.nav.aetheris}</a>
      <a href={siteHref('/wiki', links.wikiSite)}>{t.nav.wiki}</a>
      <a href={siteHref('/blog', links.blogSite)}>{t.nav.blog}</a>
    </nav>

    <nav aria-label={t.footer.community}>
      <h3>{t.footer.community}</h3>
      <a href={links.org} target="_blank" rel="noopener">GitHub ↗</a>
      <a href={links.discord} target="_blank" rel="noopener">Discord ↗</a>
      <a href={links.releasesAll} target="_blank" rel="noopener">Releases ↗</a>
    </nav>
  </div>

  <div class="container footer-legal">
    <p>© {year} {t.footer.rights}</p>
    <p>{t.footer.legal}</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border-color);
    background: var(--footer-bg);
    padding-block: 3.5rem 2rem;
    margin-top: 4rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 2.5rem;
    margin-bottom: 3rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 1.1rem;
  }

  .brand strong {
    color: var(--accent);
  }

  .footer-brand p {
    margin-top: 0.9rem;
    color: var(--ink-dim);
    max-width: 22rem;
  }

  nav {
    display: grid;
    gap: 0.55rem;
    align-content: start;
  }

  nav h3 {
    font-size: 0.8rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--ink-faint);
    margin-bottom: 0.4rem;
  }

  nav a {
    text-decoration: none;
    color: var(--ink-dim);
    font-size: 0.95rem;
  }

  nav a:hover {
    color: var(--accent);
  }

  .footer-legal {
    border-top: 1px solid var(--border-color);
    padding-top: 1.5rem;
    display: grid;
    gap: 0.4rem;
  }

  .footer-legal p {
    color: var(--ink-faint);
    font-size: 0.82rem;
  }

  @media (max-width: 700px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
