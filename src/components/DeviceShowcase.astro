---
import type { Lang } from '../i18n/translations';
import { translations } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = translations[lang];
---

<div class="stage" role="img" aria-label={t.hero.deviceNote}>
  <div class="device tv">
    <div class="screen aurora-screen">
      <span class="edition mono">Cast</span>
      <span class="pill">{t.hero.soon}</span>
    </div>
    <div class="tv-stand"></div>
  </div>

  <div class="device tablet">
    <div class="screen aurora-screen vertical">
      <span class="edition mono">Tablet</span>
      <span class="pill">{t.hero.soon}</span>
    </div>
  </div>

  <div class="device laptop">
    <div class="laptop-lid">
      <div class="screen aurora-screen">
        <span class="edition mono">{t.editions.items.workstation.name}</span>
        <span class="pill">{t.hero.available}</span>
      </div>
    </div>
    <div class="laptop-base"></div>
  </div>

  <div class="device phone">
    <div class="screen aurora-screen vertical">
      <span class="notch"></span>
      <span class="edition mono">Mobile</span>
      <span class="pill">{t.hero.soon}</span>
    </div>
  </div>

  <div class="device deck">
    <div class="grip grip-l">
      <span class="stick"></span>
      <span class="dpad"></span>
    </div>
    <div class="screen aurora-screen">
      <span class="edition mono">Play</span>
      <span class="pill">{t.hero.soon}</span>
    </div>
    <div class="grip grip-r">
      <span class="stick"></span>
      <span class="buttons"><i></i><i></i><i></i><i></i></span>
    </div>
  </div>

  <div class="stage-glow" aria-hidden="true"></div>
</div>

<style>
  .stage {
    position: relative;
    width: min(100%, 58rem);
    aspect-ratio: 16 / 9.5;
    margin-top: clamp(2rem, 5vw, 4rem);
    margin-inline: auto;
  }

  .stage-glow {
    display: none;
  }

  .device {
    position: absolute;
    opacity: 0;
    animation:
      device-in 1s cubic-bezier(0.2, 0.7, 0.2, 1) forwards,
      hover-float 7s ease-in-out infinite;
  }

  @keyframes device-in {
    from { opacity: 0; transform: translateY(36px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes hover-float {
    0%, 100% { margin-top: 0; }
    50% { margin-top: -8px; }
  }

  .screen {
    border-radius: inherit;
    overflow: hidden;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.45em;
    position: relative;
  }

  .aurora-screen {
    background:
      linear-gradient(180deg, rgba(53, 132, 228, 0.12), transparent 34%),
      var(--screen-night);
  }

  .edition {
    font-size: clamp(0.55rem, 1.4cqw, 1.05rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .pill {
    font-family: var(--font-mono);
    font-size: clamp(0.45rem, 1cqw, 0.7rem);
    padding: 0.25em 0.9em;
    border-radius: 999px;
    border: 1px solid var(--border-color);
    color: var(--ink-dim);
    background: var(--surface-2);
    white-space: nowrap;
  }

  .tv {
    left: 50%;
    top: 0;
    width: 56%;
    margin-left: -28%; /* keep centered: the entry animation owns `transform` */
    z-index: 1;
    animation-delay: 0.05s, 1.1s;
    container-type: inline-size;
  }

  .tv .screen {
    aspect-ratio: 16 / 9;
    border-radius: 10px;
    border: 3px solid var(--device-bezel);
    box-shadow: none;
  }

  .tv-stand {
    width: 26%;
    height: 0.9vw;
    margin: 0 auto;
    background: var(--device-bezel);
    border-radius: 0 0 8px 8px;
  }

  .laptop {
    left: 50%;
    bottom: 9%;
    width: 44%;
    margin-left: -22%; /* keep centered: the entry animation owns `transform` */
    z-index: 3;
    animation-delay: 0.25s, 1.3s;
    container-type: inline-size;
  }

  .laptop-lid {
    border: 3px solid var(--device-bezel);
    border-bottom-width: 0;
    border-radius: 12px 12px 0 0;
    background: var(--device-body);
    padding: 1.2% 1.2% 0;
  }

  .laptop .screen {
    aspect-ratio: 827 / 469;
    border-radius: 8px 8px 0 0;
  }

  .laptop-base {
    height: 1.1vw;
    background: var(--device-bezel);
    border-radius: 0 0 14px 14px;
    width: 108%;
    margin-left: -4%;
    box-shadow: none;
  }

  .tablet {
    left: 15%;
    bottom: 4%;
    width: 15%;
    z-index: 4;
    rotate: -4deg;
    animation-delay: 0.45s, 1.6s;
    container-type: inline-size;
  }

  .tablet .screen {
    aspect-ratio: 3 / 4;
    border-radius: 14px;
    border: 3px solid var(--device-bezel);
    box-shadow: none;
  }

  .phone {
    right: 34%;
    bottom: 3%;
    width: 7.5%;
    z-index: 5;
    rotate: 4deg;
    animation-delay: 0.6s, 1.9s;
    container-type: inline-size;
  }

  .phone .screen {
    aspect-ratio: 9 / 19;
    border-radius: 16px;
    border: 3px solid var(--device-bezel);
    box-shadow: none;
  }

  .notch {
    position: absolute;
    top: 4%;
    left: 50%;
    transform: translateX(-50%);
    width: 34%;
    height: 2.5%;
    border-radius: 999px;
    background: var(--device-bezel);
  }

  .deck {
    right: 9%;
    bottom: 10%;
    width: 23%;
    z-index: 3;
    display: flex;
    align-items: stretch;
    animation-delay: 0.75s, 2.2s;
    container-type: inline-size;
    filter: none;
  }

  .deck .screen {
    aspect-ratio: 16 / 10;
    border-radius: 6px;
    border: 3px solid var(--device-bezel);
    flex: 1;
  }

  .grip {
    width: 17%;
    background: var(--device-body);
    position: relative;
  }

  .grip-l {
    border-radius: 45% 6px 6px 45% / 30% 6px 6px 30%;
    margin-right: -2px;
  }

  .grip-r {
    border-radius: 6px 45% 45% 6px / 6px 30% 30% 6px;
    margin-left: -2px;
  }

  .stick {
    position: absolute;
    top: 18%;
    left: 50%;
    transform: translateX(-50%);
    width: 46%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--device-bezel);
    border: 1px solid var(--border-color);
  }

  .dpad,
  .buttons {
    position: absolute;
    bottom: 16%;
    left: 50%;
    transform: translateX(-50%);
    width: 48%;
    aspect-ratio: 1;
  }

  .dpad {
    background:
      linear-gradient(var(--device-bezel), var(--device-bezel)) 50% 0 / 34% 100% no-repeat,
      linear-gradient(var(--device-bezel), var(--device-bezel)) 0 50% / 100% 34% no-repeat;
    border-radius: 4px;
  }

  .buttons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18%;
    rotate: 45deg;
  }

  .buttons i {
    border-radius: 50%;
    background: var(--device-bezel);
  }

  @media (max-width: 640px) {
    .stage {
      aspect-ratio: 16 / 14;
    }

    .tv {
      width: 72%;
      margin-left: -36%;
    }

    .laptop {
      width: 56%;
      margin-left: -28%;
      bottom: 14%;
    }

    .tablet {
      left: 8%;
      bottom: 2%;
      width: 18%;
    }

    .phone {
      right: 36%;
      bottom: 0;
      width: 11%;
    }

    .deck {
      right: 5%;
      width: 28%;
      bottom: 4%;
    }
  }
</style>
